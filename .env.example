# Copia questo file in ".env.local" e inserisci i valori del tuo progetto Supabase.
# Le variabili EXPO_PUBLIC_* sono incluse nel bundle client (l'anon key è pensata per il client).
# I segreti veri (service role, GEMINI_API_KEY, ecc.) NON vanno qui: vivranno nelle Edge Function.

EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...la-tua-anon-key...
